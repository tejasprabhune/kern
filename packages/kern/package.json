{
  "name": "kern-typ",
  "version": "0.1.0",
  "description": "Fast, zero-dependency Typst math renderer for the browser",
  "license": "MIT",
  "author": "Tejas Prabhune",
  "homepage": "https://tejasprabhune.github.io/kern/",
  "repository": {
    "type": "git",
    "url": "https://github.com/tejasprabhune/kern.git"
  },
  "keywords": ["typst", "math", "renderer", "mathml", "katex"],
  "type": "module",
  "main": "./dist/kern.cjs",
  "module": "./dist/kern.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/kern.js",
      "require": "./dist/kern.cjs",
      "types": "./dist/index.d.ts"
    },
    "./auto-render": {
      "import": "./dist/auto-render.js",
      "require": "./dist/auto-render.cjs",
      "types": "./dist/auto-render.d.ts"
    },
    "./kern.css": "./styles/kern.css",
    "./kern-newcm.css": "./styles/kern-newcm.css"
  },
  "files": [
    "dist",
    "styles",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build && vite build --config vite.umd.config.ts && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "vitest run --config vite.visual.config.ts",
    "lint": "tsc --noEmit",
    "bench": "vitest bench",
    "prepack": "cp ../../README.md . && cp ../../LICENSE .",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "devDependencies": {
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@vitest/coverage-v8": "^1.6.0",
    "pixelmatch": "^5.3.0",
    "playwright": "^1.45.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.12",
    "vite-plugin-dts": "^3.9.1",
    "vitest": "^1.6.0"
  }
}
